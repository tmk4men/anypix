{
  "name": "anypix",
  "version": "1.0.0",
  "private": true,
  "description": "AnyPix - on-device image converter & compressor",
  "scripts": {
    "build:web": "node scripts/build-web.js",
    "prep:icon": "node scripts/prep-icon.js",
    "ios:setup": "node scripts/build-web.js && npx cap add ios && node scripts/patch-ios-plist.js && node scripts/patch-ios-podfile.js && npx @capacitor/assets generate --ios && npx cap sync ios",
    "ios:noencrypt": "node scripts/patch-ios-plist.js",
    "ios:podfix": "node scripts/patch-ios-podfile.js",
    "ios:bump": "node scripts/bump-build.js",
    "ios:sync": "node scripts/build-web.js && node scripts/patch-ios-podfile.js && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor-community/admob": "^6.1.0",
    "cordova-plugin-purchase": "^13.11.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@capacitor/assets": "^3.0.5"
  }
}
